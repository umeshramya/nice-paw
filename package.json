{
  "name": "nice-paw",
  "version": "1.0.2",
  "description": "MCP server for nicehms.com healthcare authentication",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "nice-paw": "bin/nice-paw.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "start:dev": "ts-node --esm src/index.ts",
    "clean": "rimraf dist",
    "rebuild": "npm run clean && npm run build",
    "prepare": "npm run build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --config jest.config.mjs",
    "test:watch": "jest --watch --config jest.config.mjs",
    "test:coverage": "jest --coverage --config jest.config.mjs",
    "lint": "echo \"Add ESLint if needed\"",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm test"
  },
  "files": [
    "dist",
    "bin",
    "nice-paw.png",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "nicehms",
    "healthcare",
    "authentication",
    "server"
  ],
  "author": "umeshramya <umeshbilagi@gmail.com>",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/umeshramya/nice-paw.git"
  },
  "bugs": {
    "url": "https://github.com/umeshramya/nice-paw/issues"
  },
  "homepage": "https://github.com/umeshramya/nice-paw#readme",
  "type": "module",
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "jest": "^29.7.0",
    "rimraf": "^6.1.3",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/server": "^2.0.0-alpha.2",
    "dotenv": "^17.4.1",
    "zod": "^4.3.6"
  }
}
